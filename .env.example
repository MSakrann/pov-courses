DATABASE_URL="postgresql://user:pass@localhost:5432/pov_courses?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

VDOCIPHER_API_KEY=""

KASHIER_MERCHANT_ID=""
KASHIER_API_KEY=""
KASHIER_IFRAME_SECRET=""
# Server-to-server webhook secret (dashboard webhook URL = {NEXT_PUBLIC_BASE_URL}/api/webhooks/kashier)
KASHIER_WEBHOOK_SECRET=""
KASHIER_MODE="test"

ACCESS_DAYS=180
PRIVATE_IMAGES_PATH="./private/images"

# YouTube video ID (11 characters) for “teaching style preview” under Meet the instructors
NEXT_PUBLIC_TEACHING_PREVIEW_YOUTUBE_ID=""

# Public site origin — used for Kashier browser return (/api/checkout/kashier-return)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_COURSE_PRICE="1450"
NEXT_PUBLIC_ORIGINAL_PRICE="7000"
NEXT_PUBLIC_SALE_END_AT="2026-12-31T23:59:59.000Z"
NEXT_PUBLIC_KASHIER_CURRENCY="EGP"
NEXT_PUBLIC_KASHIER_DESCRIPTION="Course access"
NEXT_PUBLIC_KASHIER_STORE="Pov Courses"
NEXT_PUBLIC_KASHIER_DISPLAY="en"
NEXT_PUBLIC_KASHIER_ALLOWED_METHODS="card,wallet"

VDOCIPHER_DEMO_ID="your-demo-video-id"

# Upstash (optional: login rate limit; omit in local dev to allow all)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
